# syntax = docker/dockerfile:1
# This Dockerfile uses multi-stage build to customize DEV and PROD images:
# https://docs.docker.com/develop/develop-images/multistage-build/

FROM python:3.12-bookworm AS dependency_build
ARG OS_VERSION=master
ARG OS_CONSTRAINTS=master
RUN apt-get update && apt-get upgrade -y \
  && apt-get install --no-install-recommends -y \
                                             bash \
                                             brotli \
                                             build-essential \
                                             curl \
                                             docutils-common \
                                             gettext \
                                             git \
                                             libffi-dev \
                                             libopenmpi-dev \
                                             libjs-sphinxdoc \
                                             libjs-underscore \
                                             libldap2-dev \
                                             libpq-dev \
                                             libsasl2-dev \
                                             libssl-dev \
                                             libsystemd-dev \
                                             libxml2-dev \
                                             libxslt1-dev \
                                             libxslt1.1 \
                                             pkg-config \
                                             ssl-cert \
                                             xmlsec1
RUN python3 -m venv /var/lib/openstack
RUN /var/lib/openstack/bin/pip install --upgrade pip setuptools
ENV PATH="/var/lib/openstack/bin:$PATH" \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PIP_DEFAULT_TIMEOUT=100 \
    PYTHONUNBUFFERED=1
RUN /var/lib/openstack/bin/pip install --constraint https://opendev.org/openstack/requirements/raw/branch/${OS_CONSTRAINTS}/upper-constraints.txt \
                                       git+https://opendev.org/openstack/heat.git@${OS_VERSION}#egg=openstack-heat \
                                       PyMySQL \
                                       uwsgi

COPY scripts/heat-cve-patching.sh /opt/
RUN bash /opt/heat-cve-patching.sh

RUN find / -name '*.pyc' -delete \
  && find / -name '*.pyo' -delete \
  && find / -name '__pycache__' -delete \
  && find / -name '*.whl' -delete \
  && rm -f /var/lib/openstack/lib/python*/site-packages/slapdtest/certs/client.key \
  && rm -f /var/lib/openstack/lib/python*/site-packages/slapdtest/certs/server.key


FROM python:3.12-slim-bookworm as production_build
LABEL maintainer="Rackspace"
LABEL vendor="Rackspace OpenStack Team"
LABEL org.opencontainers.image.name="heat"
LABEL org.opencontainers.image.description="OpenStack Service (heat) built for the enterprise."
COPY --from=dependency_build /var/lib/openstack /var/lib/openstack
EXPOSE 5000 35357
RUN apt-get update && apt-get upgrade -y \
  && apt-get install --no-install-recommends -y libxml2 \
                                                libxslt1.1 \
                                                libopenmpi3 \
  && apt-get purge -y --auto-remove -o APT::AutoRemove::RecommendsImportant=false \
  && apt-get clean -y \
  && rm -rf /var/lib/apt/lists/* \
  && find / -name '*.pyc' -delete \
  && find / -name '*.pyo' -delete \
  && find / -name '__pycache__' -delete \
  && groupadd --system --gid 42424 heat \
  && useradd --system --gid 42424 --uid 42424 --shell /sbin/nologin --create-home --home /var/lib/heat heat \
  && ln -s /var/lib/openstack/etc/heat /etc/heat \
  && mkdir -p /etc/heat/credential-keys \
  && mkdir -p /etc/heat/fernet-keys \
  && chown heat:heat -h /etc/heat \
  && chown -R heat:heat /var/lib/openstack/etc/heat
# Set the environment variables for the heat venv
ENV PATH="/var/lib/openstack/bin:$PATH"
# Set the working directory
WORKDIR /var/lib/openstack
# Set the user and group to match the original build
USER 42424:42424
# Set the entrypoint to the heat-manage command
ENTRYPOINT ["/var/lib/openstack/bin/heat-manage"]
